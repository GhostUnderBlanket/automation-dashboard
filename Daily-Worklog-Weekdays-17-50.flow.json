{
  "$schema": "autoflow.flow",
  "version": 1,
  "exportedAt": 1779275618075,
  "flow": {
    "id": "flow-1779273365546-l63r",
    "name": "Daily Worklog · Weekdays 17:50",
    "description": "Runs at 17:50 on weekdays. Queries PlasticSCM for today's LOB-Ticket attribute values, averages 8 hours across unique tickets, then POSTs a worklog entry for each via Polaris REST API. If no tickets found, opens Cronos for manual logging.",
    "variables": {
      "HOURS": "8",
      "ATTRIBUTE": "LOB-Ticket",
      "DIRECTORY": "D:\\Workspaces\\LeagueOfBomb"
    },
    "tags": [
      "worklog",
      "plasticscm",
      "polaris"
    ],
    "nodes": [
      {
        "id": "wl-trigger",
        "type": "trigger",
        "label": "Weekdays 17:50",
        "position": {
          "x": 0,
          "y": 100
        },
        "data": {
          "mode": "cron",
          "cron": "50 17 * * 1-5",
          "catchUp": "skip",
          "enabled": true
        }
      },
      {
        "id": "wl-tickets",
        "type": "script",
        "label": "Get tickets",
        "position": {
          "x": 240,
          "y": 100
        },
        "data": {
          "shell": "powershell",
          "workDir": "${var:DIRECTORY}",
          "script": "$date = Get-Date -Format \"yyyy-MM-dd\"\n$raw = cm find attributes \"where type = '${var:ATTRIBUTE}' and date >= '$date 00:00:00' and date <= '$date 23:59:59' and owner = '$(cm whoami)'\" --format=\"{value}\" --nototal 2>&1\n$tickets = @($raw | Where-Object { $_ -match '\\S' } | Select-Object -Unique)\nif ($tickets.Count -eq 0) { Write-Output \"[]\"; exit 0 }\n$hours = [math]::Round(${var:HOURS} / $tickets.Count, 2)\n$items = $tickets | ForEach-Object { '{\"taskId\":\"' + $_ + '\",\"hours\":' + $hours + ',\"date\":\"' + $date + '\"}' }\nWrite-Output (\"[\" + ($items -join \",\") + \"]\")"
        }
      },
      {
        "id": "wl-check-empty",
        "type": "condition",
        "label": "No tickets?",
        "position": {
          "x": 480,
          "y": 100
        },
        "data": {
          "source": "${wl-tickets}",
          "op": "equals",
          "value": "[]"
        }
      },
      {
        "id": "wl-loop",
        "type": "loop",
        "label": "For each ticket",
        "position": {
          "x": 480,
          "y": 260
        },
        "data": {
          "mode": "forEach",
          "separator": "json-array",
          "delay": 500
        }
      },
      {
        "id": "wl-rest",
        "type": "rest",
        "label": "Add worklog",
        "position": {
          "x": 720,
          "y": 260
        },
        "data": {
          "method": "POST",
          "endpoint": "api/v1/polaris_add_worklog",
          "urlOverride": "",
          "bodyMode": "form",
          "bodyRows": [
            {
              "key": "taskId",
              "value": "${loop.item.taskId}"
            },
            {
              "key": "hours",
              "value": "${loop.item.hours}"
            },
            {
              "key": "date",
              "value": "${loop.item.date}"
            }
          ]
        }
      },
      {
        "id": "wl-rest-ok",
        "type": "condition",
        "label": "Success?",
        "position": {
          "x": 960,
          "y": 260
        },
        "data": {
          "source": "${wl-rest.exit}",
          "op": "equals",
          "value": "0"
        }
      },
      {
        "id": "wl-open-cronos",
        "type": "openurl",
        "label": "Open Cronos",
        "position": {
          "x": 960,
          "y": 100
        },
        "data": {
          "url": "https://polaris.nanuq.co.th/#chronos"
        }
      }
    ],
    "edges": [
      {
        "id": "wl-e1",
        "source": "wl-trigger",
        "target": "wl-tickets"
      },
      {
        "id": "wl-e2",
        "source": "wl-tickets",
        "target": "wl-check-empty"
      },
      {
        "id": "wl-e3",
        "source": "wl-check-empty",
        "target": "wl-open-cronos",
        "sourceHandle": "true"
      },
      {
        "id": "wl-e4",
        "source": "wl-check-empty",
        "target": "wl-loop",
        "sourceHandle": "false"
      },
      {
        "id": "wl-e5",
        "source": "wl-loop",
        "target": "wl-rest"
      },
      {
        "id": "wl-e6",
        "source": "wl-rest",
        "target": "wl-rest-ok"
      },
      {
        "id": "wl-e7",
        "source": "wl-rest-ok",
        "target": "wl-open-cronos",
        "sourceHandle": "true"
      }
    ],
    "status": "success",
    "createdAt": 1779273365546,
    "updatedAt": 1779273365546,
    "lastRun": 1779275555369
  }
}